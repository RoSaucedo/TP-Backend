@model GestorDespacho.Models.Cliente

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Cliente</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Nombre)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Nombre)
        </dd>

        <dt class="col-sm-2" translate="no">
            @Html.DisplayNameFor(model => model.CUIT)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CUIT)
        </dd>
    </dl>
</div>

<hr />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Direcciones Registradas</h3>
    <a asp-controller="Direccion" asp-action="Create" class="btn btn-success">Agregar Dirección</a>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Calle y Número</th>
            <th>Ciudad</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Direcciones != null && Model.Direcciones.Any())
        {
            foreach (var dir in Model.Direcciones)
            {
                <tr>
                    <td>@dir.CalleNumero</td>
                    <td>@dir.Ciudad</td>
                    <td>
                        <a asp-controller="Direccion" asp-action="Edit" asp-route-id="@dir.Id" class="btn btn-sm btn-warning">Editar</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center text-muted">Este cliente no tiene direcciones cargadas todavía.</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>