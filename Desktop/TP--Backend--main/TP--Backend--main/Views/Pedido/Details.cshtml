@model GestorDespacho.Models.Pedido

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>    

<div>
    <h4>Pedido</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Fecha)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Fecha)
        </dd>

        <dt class="col-sm-2">
            Cliente
        </dt>
        <dd class="col-sm-10">
            @(Model.Cliente != null ? Model.Cliente.Nombre : "No asignado")
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.NombreUsuario)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.NombreUsuario)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MontoTotal)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MontoTotal)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TotalProductos)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TotalProductos)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Confirmado)
        </dt>
        <dd class="col-sm-10">
            @if (Model.Confirmado)
            {
                <span class="badge bg-success">Confirmado</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">Pendiente</span>
            }
        </dd>
    </dl>
</div>

<hr />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Productos en este Pedido</h3>
    @if (!Model.Confirmado)
    {
        <a asp-controller="PedidoDetalle" asp-action="Create" asp-route-pedidoId="@Model.Id" class="btn btn-success">Agregar Producto</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Costo Unitario</th>
                <th>Subtotal</th>
                @if (!Model.Confirmado)
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @* CORREGIDO: Volvimos a usar Model.Detalles que es el posta *@
            @if (Model.Detalles != null && Model.Detalles.Any())
            {
                foreach (var item in Model.Detalles)
                {
                    <tr>
                        <td>@(item.Producto != null ? item.Producto.Descripcion : "Producto Especial")</td>
                        <td>@item.Cantidad</td>
                        <td>@item.CostoUnitario.ToString("C")</td>
                        <td>@item.Subtotal.ToString("C")</td>
                        @if (!Model.Confirmado)
                        {
                            <td>
                                <a asp-controller="PedidoDetalle" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                                <a asp-controller="PedidoDetalle" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                            </td>
                        }
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="@(Model.Confirmado ? "4" : "5")" class="text-center text-muted">
                        No hay productos cargados en este pedido todavía.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-4 d-flex align-items-center gap-2 flex-wrap">
    @if (!Model.Confirmado)
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a>

        <form asp-action="Confirmar" asp-route-id="@Model.Id" method="post" class="d-inline m-0">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">Confirmar Pedido</button>
        </form>

        <span class="text-muted">|</span>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>